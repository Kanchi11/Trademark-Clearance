# === REQUIRED ===
# Database (Supabase or local PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# === OPTIONAL (but recommended) ===
# Redis Cache (for faster repeated searches)
# Without this, in-memory cache will be used (data lost on restart)
# Recommended: Upstash Redis free tier - https://upstash.com
REDIS_URL=redis://default:password@host:port
# OR use Upstash Redis REST URL
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io

# Common Law Search APIs (for automated web research)
# Choose ONE option - Bing is recommended (better free tier)
# Without these, manual search links will still be provided

# OPTION 1 (RECOMMENDED): Bing Web Search API
# Free tier: 1000 searches/month
# Get key at: https://portal.azure.com (see COMMON_LAW_SETUP.md)
BING_SEARCH_API_KEY=your_bing_api_key

# OPTION 2: Google Custom Search API
# Free tier: 100 searches/day (more limited than Bing)
# Setup at: https://console.cloud.google.com
GOOGLE_API_KEY=your_google_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# ------------------------------------------------------------------------------
# SETUP INSTRUCTIONS
# ------------------------------------------------------------------------------
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Get DATABASE_URL - Choose ONE option:
#
#    OPTION A (RECOMMENDED FOR REVIEWERS):
#    - Use read-only database for instant access
#    - Contact kds@ncsu.edu for read-only connection string
#    - No downloads or imports needed!
#
#    OPTION B (FOR YOUR OWN DATABASE):
#    - Create a free Supabase account (https://supabase.com)
#    - OR use local PostgreSQL
#    - Download USPTO XML files (see README.md)
#    - Run: npm run batch-import
#
# 3. (Optional) Set up Redis cache for faster searches:
#    - Create free Upstash Redis account (https://upstash.com)
#    - Create a Redis database
#    - Copy connection string to REDIS_URL
#    - Without this, in-memory cache will be used (works fine for dev)
#
# 4. (Optional) Get Google API credentials for automated common law search:
#    - See GOOGLE_API_SETUP.md for detailed instructions
#    - Manual search links work without API

# ------------------------------------------------------------------------------
# RAG PIPELINE (ChromaDB + CLIP + ML microservice)
# See docs/RAG_ARCHITECTURE.md for full setup.
# ------------------------------------------------------------------------------
# Set RAG_AGENT_ENABLED=true to use vector search + LLM instead of legacy DB search.
# RAG_AGENT_ENABLED=false
# AI_MICROSERVICE_URL=http://localhost:8000
# CHROMA_URL=http://localhost:8001
# CHROMA_API_KEY=
# CHROMA_TENANT=default-tenant
# CHROMA_DATABASE=default

